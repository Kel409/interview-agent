# Copy this file to ".env" and fill in the values for whichever option you use.
# (See the README, "Running it", for Option A vs Option B.)

# --- Option A: LiveKit inference gateway (the default in interview_agent.py) ---
# Get these from your LiveKit Cloud project: Settings -> Keys.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# --- Option B: direct OpenAI plugin (only if you switch the models over) ---
# OPENAI_API_KEY=sk-...
